/ {
	fstab {
		compatible = "zephyr,fstab";
		lfs1: lfs1 {
			compatible = "zephyr,fstab,littlefs";
			mount-point = "/lfs";
			partition = <&lfs1_partition>;
			automount;
			read-size = <16>;
			prog-size = <16>;
			cache-size = <256>;
			lookahead-size = <16>;
			block-cycles = <512>;
		};
	};
};

&flash0 {
	reg = <0x00000000 0x00200000>;

	partitions {
		lfs1_partition: partition@100000 {
			label = "littlefs-storage";
			reg = <0x00100000 0x00080000>;
		};
	};
};
